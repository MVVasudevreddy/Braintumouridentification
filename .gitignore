train.cache
valid.cache
test.cache

# Model weights (large files)
*.pt
*.pth
*.onnx
*.engine

# Dataset images (download from Kaggle separately)
datasets/
*.jpg
*.jpeg
*.png
*.bmp

# Log files
*.log

# OS files
.DS_Store
Thumbs.db

# Google Colab / Drive artifacts
.config/
content/
